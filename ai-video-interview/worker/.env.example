AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Optional if you use an AWS profile instead of raw keys
AWS_PROFILE=
AWS_SESSION_TOKEN=
# Optional, useful when loading AWS profile/config files on Windows
AWS_SDK_LOAD_CONFIG=1
S3_BUCKET=your-bucket-name
SQS_URL=https://sqs.us-east-1.amazonaws.com/123456789012/merge-queue
TRANSCRIBE_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/transcribe-queue
DEEPGRAM_API_KEY=your-deepgram-key
BACKEND_URL=http://localhost:4000
